# ===========================================
# AI PROVIDER CONFIGURATION
# ===========================================
# Choose provider: opencode, openrouter, openai, anthropic, custom
AI_PROVIDER=opencode

# OpenCode Zen (default)
OPENCODE_API_KEY=your_opencode_key

# OpenRouter (multi-provider)
# OPENROUTER_API_KEY=your_openrouter_key

# OpenAI
# OPENAI_API_KEY=your_openai_key

# Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_key

# Custom OpenAI-compatible
# CUSTOM_API_URL=https://your-endpoint.com/v1
# CUSTOM_API_KEY=your_custom_key

# Model selection
# AI_MODEL=gpt-4-turbo
# AI_MODEL=claude-3-opus-20240229
# AI_MODEL=opencode/zen

# ===========================================
# SEO CONFIGURATION
# ===========================================
TARGET_KEYWORD=your_primary_keyword
CONTENT_TYPE=blog  # blog, product, landing, service, faq
LANGUAGE=en
COUNTRY=us

# ===========================================
# KEYWORD RESEARCH APIs (Optional)
# ===========================================
SEMRUSH_API_KEY=your_semrush_api_key

# ===========================================
# DASHBOARD & OAUTH CONFIGURATION
# ===========================================
SITE_URL=https://yourdomain.com

# Google OAuth (for Search Console & Analytics)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Google Search Console API (direct access without OAuth)
GOOGLE_API_KEY=your_google_api_key

# Bing Webmaster Tools API
BING_API_KEY=your_bing_api_key

# Google Analytics 4
GA4_PROPERTY_ID=your_ga4_property_id
GA4_API_SECRET=your_ga4_api_secret

# ===========================================
# LOCAL SEO
# ===========================================
BUSINESS_NAME=Your Business Name
LOCATIONS=New York,Los Angeles,Chicago

# ===========================================
# NOTIFICATIONS
# ===========================================
NOTIFICATION_EMAIL=youremail@example.com
AUTO_GENERATE_TASKS=true

# ===========================================
# SERVER
# ===========================================
PORT=3000